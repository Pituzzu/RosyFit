{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information, diet settings, and progress.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "weight": { "type": "number" },
        "height": { "type": "number" },
        "age": { "type": "integer" },
        "gender": { "type": "string" },
        "activityLevel": { "type": "string" },
        "dietGoal": { "type": "string" },
        "bmi": { "type": "number" },
        "dailyCalories": { "type": "number" },
        "dietStartDate": { "type": "string" },
        "selectedWeekId": { "type": "string" },
        "weeklyDiets": { "type": "object" },
        "weeklyTargets": { "type": "array" },
        "lastTargetUpdateWeek": { "type": "string" },
        "friends": { "type": "array" },
        "friendRequests": { "type": "array" },
        "sentRequests": { "type": "array" },
        "streak": { "type": "number" },
        "lastStreakDate": { "type": "string" },
        "inviteCode": { "type": "string" },
        "avatar": { "type": "string" },
        "waterGoal": { "type": "number" },
        "targetWeight": { "type": "number" },
        "isDietPublic": { "type": "boolean" }
      },
      "required": ["uid", "name", "email"]
    },
    "GameScore": {
      "title": "Game Score",
      "description": "High scores for the Healthy Crush mini-game.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "score": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "score", "timestamp"]
    },
    "Meal": {
      "title": "Meal",
      "description": "A meal post shared by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userAvatar": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "likes": { "type": "array" }
      },
      "required": ["userId", "image", "timestamp"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notifications.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "fromUserId": { "type": "string" },
        "fromUserName": { "type": "string" },
        "type": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" },
        "link": { "type": "string" },
        "handled": { "type": "boolean" }
      },
      "required": ["userId", "message", "timestamp"]
    },
    "DailyStats": {
      "title": "Daily Stats",
      "description": "Daily tracking stats like water intake.",
      "type": "object",
      "properties": {
        "water": { "type": "number" },
        "date": { "type": "string" }
      },
      "required": ["date"]
    },
    "News": {
      "title": "News",
      "description": "App news and updates.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string" },
        "active": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content"]
    },
    "Settings": {
      "title": "Settings",
      "description": "User settings.",
      "type": "object",
      "properties": {
        "isActive": { "type": "boolean" },
        "days": { "type": "array" },
        "timeOfDay": { "type": "string" }
      }
    },
    "DietProgress": {
      "title": "Diet Progress",
      "description": "Tracks consumed meals history.",
      "type": "object",
      "properties": {
        "history": { "type": "object" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data."
    },
    "/gameScores/{scoreId}": {
      "schema": "GameScore",
      "description": "Global leaderboard for the mini-game."
    },
    "/meals/{mealId}": {
      "schema": "Meal",
      "description": "Social feed posts."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications."
    },
    "/dailyStats/{statId}": {
      "schema": "DailyStats",
      "description": "Daily user statistics."
    },
    "/news/{newsId}": {
      "schema": "News",
      "description": "Global news."
    },
    "/settings/{userId}": {
      "schema": "Settings",
      "description": "User settings."
    },
    "/dietProgress/{userId}": {
      "schema": "DietProgress",
      "description": "User diet progress tracking."
    }
  }
}
